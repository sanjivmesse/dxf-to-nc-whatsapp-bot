[Unit]
Description=DXF to NC WhatsApp Bot
After=network.target

[Service]
Type=simple
User=pi
WorkingDirectory=/home/pi/dxf-to-nc-whatsapp-bot
ExecStart=/usr/bin/python3 /home/pi/dxf-to-nc-whatsapp-bot/main.py
Restart=on-failure
RestartSec=10
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
